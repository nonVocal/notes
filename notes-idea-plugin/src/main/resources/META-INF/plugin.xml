<idea-plugin>
    <id>dev.nonvocal.notes.idea</id>
    <name>Notes</name>
    <version>1.0.0</version>
    <vendor email="notes@example.com" url="https://example.com">Notes Project</vendor>

    <description><![CDATA[
        Integrates the Notes application into IntelliJ IDEA.<br>
        <ul>
            <li>Persistent <b>tool window sidebar</b> with TUI-style two-panel layout (All Notes / New Note / Search)</li>
            <li>Floating <b>dialog window</b> with the same layout – open anywhere with Ctrl+Alt+N</li>
            <li>Quick-create action via menu or shortcut (Ctrl+Shift+N)</li>
            <li>Ctrl+F focuses the Search view inside both surfaces</li>
        </ul>
    ]]></description>

    <!-- Compatible with IDEA 2023.1 and later -->
    <idea-version since-build="231"/>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Persistent sidebar (tool window) -->
        <toolWindow id="Notes"
                    anchor="right"
                    factoryClass="dev.nonvocal.notes.idea.NotesToolWindowFactory"
                    icon="/icons/notes13.svg"/>
    </extensions>

    <actions>
        <group id="NotesGroup" text="Notes" description="Notes actions" popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>

            <!-- Open the floating Notes dialog window -->
            <action id="NotesDialogAction"
                    class="dev.nonvocal.notes.idea.action.NotesDialogAction"
                    text="Notes Dialog Window…"
                    description="Open the Notes two-panel UI in a floating dialog">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt N"/>
            </action>

            <action id="NotesNewAction"
                    class="dev.nonvocal.notes.idea.action.NewNoteAction"
                    text="New Note…"
                    description="Create a new note"
                    icon="AllIcons.General.Add">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift N"/>
            </action>

            <action id="NotesListAction"
                    class="dev.nonvocal.notes.idea.action.ListNotesAction"
                    text="Show All Notes"
                    description="Open the Notes tool window"/>
        </group>
    </actions>
</idea-plugin>



