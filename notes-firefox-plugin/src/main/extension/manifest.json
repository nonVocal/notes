{
  "manifest_version": 2,
  "name": "Notes",
  "version": "1.0.0",
  "description": "Quick access to your Notes application from Firefox.",
  "author": "Notes Project",

  "permissions": [
    "storage",
    "activeTab",
    "http://localhost:8080/*"
  ],

  "background": {
    "scripts": ["background/background.js"],
    "persistent": false
  },

  "browser_action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_popup": "popup/popup.html",
    "default_title": "Notes"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

